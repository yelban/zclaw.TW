/*
 * Built-in tool registry.
 *
 * Add a new firmware tool in three steps:
 * 1) Implement the handler in main/tools_*.c with tool_execute_fn signature.
 * 2) Declare the handler in main/tools_handlers.h.
 * 3) Add one TOOL_ENTRY(...) line below.
 */

// GPIO
TOOL_ENTRY("gpio_write",
           "Set a GPIO pin HIGH or LOW. Controls LEDs, relays, outputs.",
           "{\"type\":\"object\",\"properties\":{\"pin\":{\"type\":\"integer\",\"description\":\"GPIO pin allowed by GPIO Tool Safety policy\"},\"state\":{\"type\":\"integer\",\"description\":\"0=LOW, 1=HIGH\"}},\"required\":[\"pin\",\"state\"]}",
           tools_gpio_write_handler)
TOOL_ENTRY("gpio_read",
           "Read a GPIO pin state. Returns HIGH or LOW.",
           "{\"type\":\"object\",\"properties\":{\"pin\":{\"type\":\"integer\",\"description\":\"GPIO pin allowed by GPIO Tool Safety policy\"}},\"required\":[\"pin\"]}",
           tools_gpio_read_handler)
TOOL_ENTRY("gpio_read_all",
           "Read all tool-allowed GPIO pin states in a single call. Use this when user asks for all GPIO states.",
           "{\"type\":\"object\",\"properties\":{}}",
           tools_gpio_read_all_handler)
TOOL_ENTRY("delay",
           "Wait for specified milliseconds (max 60000). Use between GPIO operations.",
           "{\"type\":\"object\",\"properties\":{\"milliseconds\":{\"type\":\"integer\",\"description\":\"Time to wait in ms (max 60000)\"}},\"required\":[\"milliseconds\"]}",
           tools_delay_handler)
TOOL_ENTRY("i2c_scan",
           "Scan I2C bus for responding 7-bit addresses on selected SDA/SCL pins.",
           "{\"type\":\"object\",\"properties\":{\"sda_pin\":{\"type\":\"integer\",\"description\":\"GPIO pin for SDA (subject to GPIO Tool Safety policy)\"},\"scl_pin\":{\"type\":\"integer\",\"description\":\"GPIO pin for SCL (subject to GPIO Tool Safety policy)\"},\"frequency_hz\":{\"type\":\"integer\",\"description\":\"I2C bus speed in Hz (optional, default 100000)\"}},\"required\":[\"sda_pin\",\"scl_pin\"]}",
           tools_i2c_scan_handler)

// Memory
TOOL_ENTRY("memory_set",
           "Store a value in persistent user memory. Key must start with u_.",
           "{\"type\":\"object\",\"properties\":{\"key\":{\"type\":\"string\",\"description\":\"User key (max 15 chars, must start with u_)\"},\"value\":{\"type\":\"string\",\"description\":\"Value to store\"}},\"required\":[\"key\",\"value\"]}",
           tools_memory_set_handler)
TOOL_ENTRY("memory_get",
           "Retrieve a value from persistent user memory. Key must start with u_.",
           "{\"type\":\"object\",\"properties\":{\"key\":{\"type\":\"string\",\"description\":\"User key to retrieve (must start with u_)\"}},\"required\":[\"key\"]}",
           tools_memory_get_handler)
TOOL_ENTRY("memory_list",
           "List all user memory keys (u_*).",
           "{\"type\":\"object\",\"properties\":{}}",
           tools_memory_list_handler)
TOOL_ENTRY("memory_delete",
           "Delete a key from persistent user memory. Key must start with u_.",
           "{\"type\":\"object\",\"properties\":{\"key\":{\"type\":\"string\",\"description\":\"User key to delete (must start with u_)\"}},\"required\":[\"key\"]}",
           tools_memory_delete_handler)
TOOL_ENTRY("set_persona",
           "Set assistant tone persona. Call only when the user explicitly asks to change persona/tone settings. Affects wording only, never tool or safety behavior.",
           "{\"type\":\"object\",\"properties\":{\"persona\":{\"type\":\"string\",\"enum\":[\"neutral\",\"friendly\",\"technical\",\"witty\"],\"description\":\"Persona name\"}},\"required\":[\"persona\"]}",
           tools_set_persona_handler)
TOOL_ENTRY("get_persona",
           "Get current assistant tone persona. Use when user asks which persona is active.",
           "{\"type\":\"object\",\"properties\":{}}",
           tools_get_persona_handler)
TOOL_ENTRY("reset_persona",
           "Reset assistant tone persona back to neutral. Call only when user explicitly asks to reset persona/tone settings.",
           "{\"type\":\"object\",\"properties\":{}}",
           tools_reset_persona_handler)

// Cron/Scheduler
TOOL_ENTRY("cron_set",
           "Create a scheduled task. Type 'periodic' runs every N minutes. Type 'daily' runs at a specific local time in the device timezone (see set_timezone/get_timezone). Type 'once' runs one time after N minutes.",
           "{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\",\"enum\":[\"periodic\",\"daily\",\"once\"]},\"interval_minutes\":{\"type\":\"integer\",\"description\":\"For periodic: minutes between runs\"},\"delay_minutes\":{\"type\":\"integer\",\"description\":\"For once: minutes from now before one-time run\"},\"hour\":{\"type\":\"integer\",\"description\":\"For daily: hour 0-23\"},\"minute\":{\"type\":\"integer\",\"description\":\"For daily: minute 0-59\"},\"action\":{\"type\":\"string\",\"description\":\"What to do when triggered\"}},\"required\":[\"type\",\"action\"]}",
           tools_cron_set_handler)
TOOL_ENTRY("cron_list",
           "List all scheduled tasks.",
           "{\"type\":\"object\",\"properties\":{}}",
           tools_cron_list_handler)
TOOL_ENTRY("cron_delete",
           "Delete a scheduled task by ID.",
           "{\"type\":\"object\",\"properties\":{\"id\":{\"type\":\"integer\",\"description\":\"Schedule ID to delete\"}},\"required\":[\"id\"]}",
           tools_cron_delete_handler)
TOOL_ENTRY("get_time",
           "Get current date and time in the configured device timezone.",
           "{\"type\":\"object\",\"properties\":{}}",
           tools_get_time_handler)
TOOL_ENTRY("set_timezone",
           "Set device timezone used by get_time and daily cron schedules. Accepts common aliases (UTC, America/Los_Angeles, America/Denver, America/Chicago, America/New_York) or a POSIX TZ string.",
           "{\"type\":\"object\",\"properties\":{\"timezone\":{\"type\":\"string\",\"description\":\"Timezone alias or POSIX TZ string\"}},\"required\":[\"timezone\"]}",
           tools_set_timezone_handler)
TOOL_ENTRY("get_timezone",
           "Get current device timezone (POSIX string and abbreviation).",
           "{\"type\":\"object\",\"properties\":{}}",
           tools_get_timezone_handler)

// System
TOOL_ENTRY("get_version",
           "Get current firmware version.",
           "{\"type\":\"object\",\"properties\":{}}",
           tools_get_version_handler)

// Health
TOOL_ENTRY("get_health",
           "Get device health status: heap memory, rate limits, time sync, version.",
           "{\"type\":\"object\",\"properties\":{}}",
           tools_get_health_handler)
TOOL_ENTRY("get_diagnostics",
           "Get detailed runtime diagnostics. Optional scope: quick, runtime, memory, rates, time, all. Optional verbose=true for expanded output.",
           "{\"type\":\"object\",\"properties\":{\"scope\":{\"type\":\"string\",\"enum\":[\"quick\",\"runtime\",\"memory\",\"rates\",\"time\",\"all\"],\"description\":\"Optional diagnostics scope (default quick)\"},\"verbose\":{\"type\":\"boolean\",\"description\":\"Include extra details (default false)\"}}}",
           tools_get_diagnostics_handler)

// User Tool Management
TOOL_ENTRY("create_tool",
           "Create a custom tool. Provide a short name (no spaces), brief description, and the action to perform when called.",
           "{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\",\"description\":\"Tool name (alphanumeric, no spaces)\"},\"description\":{\"type\":\"string\",\"description\":\"Short description for tool list\"},\"action\":{\"type\":\"string\",\"description\":\"What to do when tool is called\"}},\"required\":[\"name\",\"description\",\"action\"]}",
           tools_create_tool_handler)
TOOL_ENTRY("list_user_tools",
           "List all user-created custom tools.",
           "{\"type\":\"object\",\"properties\":{}}",
           tools_list_user_tools_handler)
TOOL_ENTRY("delete_user_tool",
           "Delete a user-created custom tool by name.",
           "{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\",\"description\":\"Tool name to delete\"}},\"required\":[\"name\"]}",
           tools_delete_user_tool_handler)
